---
import logoCircle from "@/assets/media/ai_slop_logo_circle.png?url";
import EcoModeToggleButton from "@/components/islands/EcoModeToggleButton";

const links = [
  { label: "Papers", href: "/papers" },
  { label: "Submit", href: "/submit" },
  { label: "About", href: "/about" },
  { label: "FAQ", href: "/faq" },
];
---

<nav aria-label="Main" class="flex flex-col gap-3 border-b border-[color:var(--coffee-light)] bg-[color:var(--paper)]/80 px-4 py-3 backdrop-blur-sm sm:px-6 md:flex-row md:items-center md:gap-6 lg:px-8">
  <div class="flex items-center justify-between gap-3">
    <a href="/" class="flex min-w-0 items-center gap-3">
      <span class="relative h-12 w-12 shrink-0 overflow-hidden rounded-full border border-[color:var(--coffee)] bg-[color:var(--coffee-light)]/70 sm:h-14 sm:w-14">
        <img src={logoCircle} alt="AI Slop circular badge" class="h-full w-full object-cover" />
        <span class="absolute inset-1 rounded-full border border-[color:var(--coffee)] opacity-60" aria-hidden="true" />
      </span>
      <div class="min-w-0">
        <p class="truncate text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-[color:var(--ink)] sm:text-sm sm:tracking-[0.22em]">The Journal of AI Slop™</p>
        <p class="text-[0.72rem] font-serif italic text-[color:var(--ink-soft)] sm:text-sm">All Sarcasm, No Rigour.</p>
      </div>
    </a>
  </div>

  <div class="flex flex-wrap items-center gap-x-4 gap-y-3 border-t border-[color:var(--coffee-light)] pt-3 md:ml-auto md:border-t-0 md:pt-0">
    <EcoModeToggleButton client:load />
    <div class="flex flex-wrap gap-x-5 gap-y-2 text-[0.62rem] font-semibold uppercase tracking-[0.2em] text-[color:var(--ink-soft)] md:tracking-[0.28em]">
      {links.map((item) => (
        <a href={item.href} class="relative before:absolute before:-bottom-1 before:left-0 before:h-[2px] before:w-0 before:bg-[color:var(--accent-blue)] before:transition-all before:duration-200 hover:text-[color:var(--ink)] hover:before:w-full">
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>
